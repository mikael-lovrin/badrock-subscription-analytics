# Shopify Admin API (client-credentials app, no redirect URI)
SHOPIFY_SHOP_DOMAIN=fegbrands.myshopify.com
SHOPIFY_CLIENT_ID=your_client_id_here
SHOPIFY_CLIENT_SECRET=your_client_secret_here
SHOPIFY_API_VERSION=2025-01

# Appstle Subscriptions Admin API
# Generate at: Appstle admin -> Settings -> API Key Management
APPSTLE_API_KEY=apst_your_api_key_here
